# EduLingo frontend env (Vite build-time only — values are baked into the bundle)
#
# Copy to .env to override defaults during `npm run dev` or `npm run build`.
# In Docker mode, these are passed via `docker-compose.yml`'s build.args; do not
# rely on this file inside the container build.

# Base URL for the FastAPI AI proxy (TTS, streaming chat, vocabulary speech).
# Default `/ai` is correct for any deployment that fronts the stack with the
# bundled nginx (laptop, VPS). Override with an absolute URL only for split-
# origin deployments where the ai-proxy lives on a different host.
VITE_LOCAL_AI_URL=/ai

# Path to the Live2D model file served from public/.
# Override if you ship a different avatar.
VITE_LIVE2D_MODEL=/models/haru/haru_greeter_t03.model3.json

# NOTE: Backend (Spring Boot) calls intentionally use bare relative `/api/...`
# paths in src/api/*.ts. They are routed by nginx (production) and Vite's
# server.proxy (dev), so no VITE_API_BASE env var exists.
