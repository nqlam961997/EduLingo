# =============================================================================
#  EduLingo — root .env (copy this file to .env and edit).
#
#  Two deployment modes:
#    1. Laptop / classroom demo:  leave DOMAIN empty, use defaults.
#    2. VPS with HTTPS:           set DOMAIN, JWT_SECRET, POSTGRES_PASSWORD.
# =============================================================================

# -----------------------------------------------------------------------------
#  Deployment target
# -----------------------------------------------------------------------------
# REQUIRED for VPS deploys. Leave empty for laptop.
#   - empty       → Caddy serves plain HTTP on port 80.
#   - foo.com     → Caddy auto-provisions a Let's Encrypt cert for foo.com.
#                   DNS must already point to the VPS BEFORE `docker compose up`.
DOMAIN=

# Email registered with Let's Encrypt (used for renewal notices). Optional but
# recommended for VPS deploys.
ACME_EMAIL=admin@example.com

# Host port mapping for Caddy. Override if 80/443 are taken on the host.
HTTP_PORT=80
HTTPS_PORT=443

# -----------------------------------------------------------------------------
#  PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=edulingo
POSTGRES_USER=edulingo
# REQUIRED to change for VPS — leaving as `edulingo` on a public host is unsafe.
POSTGRES_PASSWORD=edulingo

# -----------------------------------------------------------------------------
#  Spring backend
# -----------------------------------------------------------------------------
# REQUIRED to change for VPS. The backend refuses to start if DOMAIN is set and
# this still equals the demo placeholder below.
# Generate a real one:  openssl rand -base64 48
JWT_SECRET=c2VjcmV0LWtleS1mb3ItZWR1bGluZ28tZGVtby1jaGFuZ2UtaW4tcHJvZHVjdGlvbg==
JWT_EXPIRATION=86400000

# CORS_ORIGINS auto-derives from DOMAIN in docker-compose.yml — only set this
# if you need to allow additional origins (e.g. staging domain, mobile app).
# CORS_ORIGINS=https://foo.com,https://staging.foo.com

# AI provider switch:  local | openai | gemini
AI_PROVIDER=local

# Required only when AI_PROVIDER=gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Required only when AI_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
#  Ollama (local AI model — only used when AI_PROVIDER=local)
# -----------------------------------------------------------------------------
# Benchmarked on CPU with the EduLingo roleplay prompt (Apple Silicon, Docker).
#   qwen2.5:3b    ~2GB,   ~3s/turn,  reliable demo default (RECOMMENDED)
#   llama3.2:3b   ~2GB,   ~4s/turn,  comparable to qwen2.5
#   gemma2:2b     ~1.6GB, ~4s/turn,  smallest disk footprint
#   qwen3:8b      ~5GB,   ~12s/turn clean / 30-100s under sustained load on CPU.
#                 Better correction quality but unstable for live demo in Docker;
#                 only viable on host-native Ollama with Metal/GPU.
#   gemma2:9b     ~5.5GB, requires GPU for reasonable speed
# Note: qwen3 thinking mode is auto-disabled in code (backend-python/main.py).
OLLAMA_MODEL=qwen2.5:3b

# Edge-TTS voice (English variants only by default).
TTS_VOICE=en-US-JennyNeural

# -----------------------------------------------------------------------------
#  Frontend build args (baked into the Vue bundle at build time)
# -----------------------------------------------------------------------------
# Defaults work for any deployment that fronts the stack with the bundled
# nginx (laptop, VPS via Caddy). Only override for split-origin setups.
VITE_LOCAL_AI_URL=/ai
VITE_LIVE2D_MODEL=/models/haru/haru_greeter_t03.model3.json
