# EduLingo — reverse proxy with conditional TLS.
#
# SITE_ADDRESS is substituted by docker-compose:
#   - DOMAIN unset → SITE_ADDRESS=":80" → plain HTTP, no certs requested.
#   - DOMAIN=foo.example.com → SITE_ADDRESS="foo.example.com" → Caddy auto-
#     provisions a Let's Encrypt certificate on first request.

{
    email {$ACME_EMAIL}
}

{$SITE_ADDRESS} {
    encode gzip

    # Streaming responses (chat, TTS) must not be buffered.
    reverse_proxy frontend:80 {
        flush_interval -1
        transport http {
            read_timeout 5m
        }
    }
}
